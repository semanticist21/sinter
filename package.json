{
  "name": "sinter",
  "version": "0.1.0",
  "type": "module",
  "description": "High-performance image processing with Rust + WASM",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "cd wasm && cargo build --release --target wasm32-unknown-unknown && cd .. && wasm-pack build wasm --target web --out-dir pkg && rslib build",
    "dev": "rslib dev",
    "check": "biome check . && tsgo && bun run rust:check",
    "test": "rstest",
    "fix": "biome check . --write && tsgo && bun run rust:fix",
    "rust:check": "cargo check --all",
    "rust:fix": "cargo fix --allow-dirty && cargo fmt --all"
  },
  "dependencies": {
    "sinter-wasm": "link:sinter-wasm"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@rslib/core": "^0.18.5",
    "@rstest/core": "^0.7.5",
    "@types/node": "^25.0.3",
    "@typescript/native-preview": "^7.0.0-dev.20251219.1",
    "vite": "^7.3.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "wasm-pack": "^0.13.1"
  }
}
